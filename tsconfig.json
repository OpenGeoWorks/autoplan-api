{
    "ts-node": {
        "files": true
    },
    "compilerOptions": {
        "target": "es2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": ["./src/*"],
            "@config/*": ["./src/config/*"],
            "@db/*": ["./src/db/*"],
            "@middlewares/*": ["./src/middlewares/*"],
            "@modules/*": ["./src/modules/*"],
            "@routes/*": ["./src/routes/*"],
            "@services/*": ["./src/services/*"],
            "@utils/*": ["./src/utils/*"]
        },
        "sourceMap": true,
        "outDir": "dist",
        "declaration": false
    },
    "include": ["src", "tests"],
    "exclude": ["node_modules", "dist"]
}
