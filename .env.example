# Server
PORT=3000
NODE_ENV=dev

# Databases
MONGO_URI=mongodb://localhost:27017/autoplan
REDIS_URI=redis://localhost:6379

# Auth
# EC private key (ES256) in PEM format with literal \n line breaks
JWT_SECRET=
# 32-byte hex string (openssl rand -hex 32)
ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=

# Companion services
PYTHON_SERVER=http://localhost:8080

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=*

# AWS SES (OTP emails)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
AWS_SES_SENDER=
